# Worker service environment variables
# Copy this file to .env and adjust values as needed.

# Node environment (dev/production)
NODE_ENV=dev
WORKER_ID=dxnet-worker-local

# Use mock aggregated result instead of fetching from network
USE_MOCK_RESULT=false
# Optional custom path to mock result JSON (defaults to ./mockResult.json)
MOCK_RESULT_PATH=./mockResult.json
# Dump aggregated result to MOCK_RESULT_PATH after a real run
DUMP_RESULT_TO_MOCK=0

# Skip cleaning up friend requests/relations (for local/mock runs)
SKIP_CLEANUP_FRIEND=false

# Dump friend-vs HTML for debugging
DUMP_FRIEND_VS_HTML=false
FRIEND_VS_HTML_DIR=./debug-html

# Server configuration
API_PORT=3999
HTTP_PROXY_PORT=2222
# Basic auth password for HTTP/CONNECT proxy (username = "admin"). Empty = no auth.
ADMIN_PASSWORD=

# Network configuration
FETCH_TIMEOUT=300000
FETCH_RETRY_COUNT=3

# Job Service API base URL
JOB_SERVICE_BASE_URL=http://127.0.0.1:9050/

# Observability is sent through backend worker endpoints. Workers do not connect
# to ClickHouse directly; set JOB_SERVICE_BASE_URL and API_SHARED_SECRET /
# ADMIN_PASSWORD so /workers/logs and /workers/dxnet/jobs/:jobId/api-calls work.

# BullMQ / Redis queue. Required for receiving dxnet jobs.
# REDIS_URL takes precedence over host/port/db/password.
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
# In production, point this at the backend host's Redis endpoint and use the
# same REDIS_PASSWORD configured in backend/docker-compose.yml.
REDIS_PASSWORD=
REDIS_KEY_PREFIX=maimai:
BULLMQ_PREFIX=
BULLMQ_JOB_RETRY_DELAY_MS=5000
# Max BullMQ jobs this DXNet worker can process concurrently for its current bot.
DXNET_WORKER_CONCURRENCY=256
MAX_PROCESS_JOBS=256
