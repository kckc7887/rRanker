# Server
PORT=9050

# MongoDB (requires username + password)
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=maimai_web

# If using the root user from docker-compose, authSource should be "admin"
MONGO_USER=root
MONGO_PASSWORD=example
MONGO_AUTH_SOURCE=admin

# Redis / BullMQ
# REDIS_URL takes precedence over host/port/db/password.
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# backend/docker-compose.yml publishes Redis for remote workers. In production,
# set REDIS_PASSWORD and restrict REDIS_BIND/6379 to worker IPs in the firewall.
REDIS_BIND=127.0.0.1
REDIS_KEY_PREFIX=maimai:
BULLMQ_PREFIX=
DXNET_DISPATCH_SWEEP_INTERVAL_MS=30000

# Music data sync
MUSIC_DATA_URL=https://www.diving-fish.com/api/maimaidxprober/music_data
# Default: every 6 hours
MUSIC_SYNC_CRON=0 */6 * * *

# Auth
AUTH_JWT_SECRET=change-me

# Admin password for /admin page access
ADMIN_PASSWORD=

# Skip auth validation (for development only)
# When true, any friendCode can login without friend request verification
SKIP_AUTH=false

# Auto Update Settings
# Cron expression for score hash sweeps (default: every 5 minutes)
AUTO_UPDATE_CRON=*/5 * * * *

# Observability / ClickHouse
# Local dev can point to the 101 ClickHouse instance; see
# docs/log-monitor-refactor/dev-testing.md.
OBSERVABILITY_ENABLED=false
OBSERVABILITY_ENV=dev
OBSERVABILITY_INSTANCE=local-backend
CLICKHOUSE_URL=http://192.168.1.101:8123
CLICKHOUSE_DATABASE=maimai_observability
CLICKHOUSE_USER=maimai_dev_writer
CLICKHOUSE_PASSWORD=
CLICKHOUSE_FLUSH_INTERVAL_MS=3000
CLICKHOUSE_MAX_BATCH_ROWS=1000
CLICKHOUSE_MAX_BUFFERED_ROWS=50000
